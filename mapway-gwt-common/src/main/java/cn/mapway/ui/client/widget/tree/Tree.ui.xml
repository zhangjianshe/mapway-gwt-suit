<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style>
        .message {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 0;
            overflow: hidden;
        }
    </ui:style>
    <g:HTMLPanel>
        <g:HTMLPanel addStyleNames="{style.message}" ui:field="lbMessage"/>
        <g:HTMLPanel ui:field="root">

        </g:HTMLPanel>
    </g:HTMLPanel>
</ui:UiBinder>