<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        @eval BORDER_RADIUS "var(--border-radius)";
        @eval COLOR_SELECTED_BK "var(--color-background-selected)";
        @eval COLOR_HOVER_BK "var(--color-background-hover)";
        @eval HIGHT "36px";
        .box {
            height: HIGHT;
            border-radius: BORDER_RADIUS;
            table-layout: fixed;
        }

        .box:HOVER {
            background-color: COLOR_HOVER_BK;
        }

        .box[select=true] {
            background-color: COLOR_SELECTED_BK;
        }

        .icon {
            width: 36px;
            text-align: center;
        }

        .lb {
            display: block;
            word-break: break-all;
            font-size: 1rem;
            line-height: HIGHT;
            overflow: hidden;
            text-overflow: ellipsis;
            height: HIGHT;
        }

        .body {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            overflow: hidden;
        }
    </ui:style>
    <g:HorizontalPanel height="36px" width="100%" addStyleNames="{style.box}" verticalAlignment="middle">
        <g:cell width="36px" verticalAlignment="middle" horizontalAlignment="center">
            <widget:FontIcon styleName="{style.icon}" ui:field="icon"/>
        </g:cell>
        <g:HTMLPanel addStyleNames="{style.body}">
            <g:Label addStyleNames="{style.lb}" ui:field="lbName"/>
            <g:HorizontalPanel ui:field="tools" spacing="4">
            </g:HorizontalPanel>
        </g:HTMLPanel>
    </g:HorizontalPanel>
</ui:UiBinder>