<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui' xmlns:widget="urn:import:cn.mapway.ui.client.widget">
    <ui:style>
        @eval BK "var(--color-background)";
        @eval BK_SELECTED "var(--color-background-selected)";
        @eval BK_HOVER "var(--color-background-hover)";
        .link {
            font-size: 1.2rem;
            cursor: pointer;
            min-width: 30px;
        }

        .link2 {
            font-size: 1rem;
        }

        .link:HOVER {
            color: #005980;
        }

        .box {
            display: flex;
            gap: 10px;
            align-items: center;
            padding: 10px;
            border-radius: 10px;
            background-color: BK;
        }


        .box:HOVER {
            background-color: BK_HOVER;
        }

        .box[select="true"] {
            background-color: BK_SELECTED;
        }

        .right {

        }
        .right:last-child{
            margin-left: auto;
        }
    </ui:style>
    <g:HTMLPanel styleName="{style.box}">
        <widget:FontIcon ui:field="icon"/>
        <g:Label ui:field="label" styleName="{style.link} {style.link2}">浏览数据集</g:Label>
        <g:HorizontalPanel ui:field="rightPanel" addStyleNames="{style.right}">
        </g:HorizontalPanel>
    </g:HTMLPanel>
</ui:UiBinder>