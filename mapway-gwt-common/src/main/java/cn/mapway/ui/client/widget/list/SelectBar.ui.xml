<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'>
    <ui:style type="cn.mapway.ui.client.widget.list.SelectBar.SStyle">
        .box {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .item {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-top: solid 1px #d0d0d0;
            border-bottom: solid 1px #d0d0d0;
            border-right: solid 1px #d0d0d0;
            height: 38px;
            padding: 4px 10px;
            font-size: 1rem;
            cursor: default;
            user-select: none;
        }

        .item:HOVER {
            background-color: #f0f0f0;
        }

        .item[select="true"] {
            background-color: #e0e0e0;
            font-weight: bold;
        }

        .one {
            border-radius: 10px;
        }

        .start {
            border-radius: 10px 0 0 10px;
            border-left: solid 1px #d0d0d0;
        }

        .end {
            border-radius: 0 10px 10px 0;
        }
    </ui:style>
    <g:HTMLPanel ui:field="root" styleName="{style.box}">

    </g:HTMLPanel>
</ui:UiBinder>